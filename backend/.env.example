# ============================================================
# CONFIGURAÇÕES DO SISTEMA DE ADVOCACIA
# Copie este arquivo para .env e preencha os valores reais
# NUNCA envie o arquivo .env para o Git
# ============================================================

# --- SERVIDOR ---
PORT=3001
NODE_ENV=development

# --- BANCO DE DADOS MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=sistema_advocacia

# --- JWT (Token de autenticação) ---
# Use uma string longa e aleatória (mínimo 32 caracteres)
JWT_SECRET=sua_chave_secreta_muito_longa_aqui_troque_isso
JWT_EXPIRES_IN=8h

# --- SUPERUSUÁRIO (dono do sistema) ---
# Credenciais do superusuário — NUNCA altere em produção sem cuidado
SUPER_LOGIN=superadmin
SUPER_SENHA=troque_essa_senha_imediatamente

# --- E-MAIL (opcional — preencher se usar módulo de e-mail) ---
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_email
EMAIL_FROM=Sistema Advocacia <seu@email.com>

# --- WHATSAPP Z-API (opcional) ---
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- AASP (opcional — preencher se usar módulo de publicações) ---
AASP_API_URL=https://api.aasp.org.br
AASP_TOKEN=

# --- BACKUP S3 (opcional — configurar no servidor) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
BACKUP_INTERVAL_HOURS=24

# --- FRONTEND URL (para CORS) ---
FRONTEND_URL=http://localhost:3000
