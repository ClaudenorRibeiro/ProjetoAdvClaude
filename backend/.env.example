# ============================================================
# CONFIGURAÇÕES DO SISTEMA DE ADVOCACIA
# Copie este arquivo para .env e preencha os valores reais
# NUNCA envie o arquivo .env para o Git
# ============================================================

# --- SERVIDOR ---
PORT=3001
NODE_ENV=development

# --- BANCO DE DADOS MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=sistema_advocacia

# --- JWT (Token de autenticação) ---
# Use uma string longa e aleatória (mínimo 32 caracteres)
JWT_SECRET=sua_chave_secreta_muito_longa_aqui_troque_isso
JWT_EXPIRES_IN=8h

# --- SUPERUSUÁRIO (dono do sistema) ---
# Credenciais do superusuário — NUNCA altere em produção sem cuidado
SUPER_LOGIN=superadmin
SUPER_SENHA=troque_essa_senha_imediatamente

# --- E-MAIL (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_email
EMAIL_FROM=Sistema Advocacia <seu@email.com>

# --- FRONTEND URL (para CORS) ---
FRONTEND_URL=http://localhost:3000

# --- DOCUMENTOS: modelos .docx no S3 (bucket privado) ---
# Bucket onde ficam os modelos .docx + credenciais do usuário IAM. Ver GUIA_S3_NOVO_CLIENTE.txt.
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- DOCUMENTOS: conversão .docx -> PDF (LibreOffice) ---
# Opcional. Se vazio, o sistema procura o soffice nos caminhos padrão e no PATH.
# Windows (ex.): C:\Program Files\LibreOffice\program\soffice.exe
# Linux/servidor: normalmente não precisa (usa o PATH após apt install libreoffice-writer)
LIBREOFFICE_PATH=
